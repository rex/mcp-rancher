{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "io.github.rex/rancher-mcp",
  "description": "Capability-aware MCP server for Rancher-managed Kubernetes: discovery, resources, workflows.",
  "status": "active",
  "repository": {
    "url": "https://github.com/rex/mcp-rancher",
    "source": "github"
  },
  "version": "1.36.0",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "rancher-mcp",
      "version": "1.36.0",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "RANCHER_URL",
          "description": "Rancher server URL (single-instance mode)",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "RANCHER_TOKEN",
          "description": "Rancher API token (token-xxxxx:yyyyyyyyy)",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "RANCHER_VERIFY_SSL",
          "description": "Verify TLS certificates (default true)",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "RANCHER_INSTANCES_JSON",
          "description": "Multi-instance config JSON (overrides single-instance mode; supports per-instance read_only)",
          "isRequired": false,
          "isSecret": true
        }
      ]
    }
  ]
}
