# Single-instance shorthand
RANCHER_URL=https://rancher.example.com
RANCHER_TOKEN=token-xxxxx:yyyyyyyyy
RANCHER_VERIFY_SSL=true
RANCHER_CA_BUNDLE=
RANCHER_READ_ONLY=false

# Multi-instance mode
# JSON object keyed by instance name. When provided, this is the preferred source.
# Example:
# RANCHER_INSTANCES_JSON={"work":{"url":"https://rancher.work.example.com","token":"token-xxxxx:yyyyyyyyy","verify_ssl":true,"ca_bundle":null,"read_only":false},"lab":{"url":"https://rancher.lab.example.com","token":"token-aaaaa:bbbbbbbbb","verify_ssl":false,"ca_bundle":null,"read_only":true}}
RANCHER_INSTANCES_JSON=
RANCHER_DEFAULT_INSTANCE=default

# Catalog and logging
RANCHER_MCP_CATALOG_PATH=catalog/capabilities.yaml
LOG_LEVEL=INFO

# Local development lab
RANCHER_MCP_LAB_RANCHER_VERSION=2.6.5
RANCHER_MCP_LAB_RANCHER_HOSTNAME=127.0.0.1.sslip.io
RANCHER_MCP_LAB_RANCHER_HTTPS_PORT=8443
RANCHER_MCP_LAB_RANCHER_AGENT_HOSTNAME=host.docker.internal
RANCHER_MCP_LAB_BOOTSTRAP_PASSWORD=rancher-admin-1234
RANCHER_MCP_LAB_RANCHER_WAIT_SECONDS=600
RANCHER_MCP_LAB_KIND_VERSION=v0.23.0
RANCHER_MCP_LAB_MANAGEMENT_CLUSTER_NAME=rancher-mcp-management
RANCHER_MCP_LAB_MANAGEMENT_NODE_IMAGE=kindest/node:v1.20.15
RANCHER_MCP_LAB_MANAGEMENT_WORKER_COUNT=1
RANCHER_MCP_LAB_MANAGEMENT_WAIT_SECONDS=300
RANCHER_MCP_LAB_DOWNSTREAM_CLUSTER_NAME=rancher-mcp-venue
RANCHER_MCP_LAB_DOWNSTREAM_NODE_IMAGE=kindest/node:v1.23.17
RANCHER_MCP_LAB_DOWNSTREAM_WORKER_COUNT=1
RANCHER_MCP_LAB_DOWNSTREAM_WAIT_SECONDS=300
RANCHER_MCP_LAB_IMPORTED_CLUSTER_NAME=venue-local
RANCHER_MCP_LAB_CERT_MANAGER_VERSION=v1.7.1

# Current Rancher integration lab. This stays isolated from the legacy dev lab
# so that its Kind clusters, port-forward, kubeconfigs, and Kind binary never
# collide with the 2.6.5 compatibility target.
RANCHER_MCP_LAB_CURRENT_RANCHER_VERSION=2.14.3
RANCHER_MCP_LAB_CURRENT_RANCHER_HOSTNAME=127.0.0.1.sslip.io
RANCHER_MCP_LAB_CURRENT_RANCHER_HTTPS_PORT=9443
RANCHER_MCP_LAB_CURRENT_RANCHER_AGENT_HOSTNAME=host.docker.internal
RANCHER_MCP_LAB_CURRENT_BOOTSTRAP_PASSWORD=rancher-admin-1234
RANCHER_MCP_LAB_CURRENT_RANCHER_WAIT_SECONDS=600
RANCHER_MCP_LAB_CURRENT_KIND_VERSION=v0.32.0
RANCHER_MCP_LAB_CURRENT_MANAGEMENT_CLUSTER_NAME=rancher-mcp-current-management
RANCHER_MCP_LAB_CURRENT_MANAGEMENT_NODE_IMAGE=kindest/node:v1.33.12
RANCHER_MCP_LAB_CURRENT_MANAGEMENT_WORKER_COUNT=0
RANCHER_MCP_LAB_CURRENT_MANAGEMENT_WAIT_SECONDS=300
RANCHER_MCP_LAB_CURRENT_DOWNSTREAM_CLUSTER_NAME=rancher-mcp-current-venue
RANCHER_MCP_LAB_CURRENT_DOWNSTREAM_NODE_IMAGE=kindest/node:v1.33.12
RANCHER_MCP_LAB_CURRENT_DOWNSTREAM_WORKER_COUNT=0
RANCHER_MCP_LAB_CURRENT_DOWNSTREAM_WAIT_SECONDS=300
RANCHER_MCP_LAB_CURRENT_IMPORTED_CLUSTER_NAME=venue-current
RANCHER_MCP_LAB_CURRENT_CERT_MANAGER_VERSION=v1.21.0
# MCP server credentials (agentic-skeleton PR3)
# These are OPTIONAL. The MCP servers will load without them, but with
# reduced capability:
#  - CONTEXT7_API_KEY: enables Context7 live-docs lookup. Without it,
#    Context7 can still list libraries but can't fetch docs.
#  - GITHUB_TOKEN: enables the github MCP. Use a fine-grained PAT scoped
#    to this repo with minimal permissions.

# CONTEXT7_API_KEY=
# GITHUB_TOKEN=
