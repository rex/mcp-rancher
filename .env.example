# Single-instance shorthand
RANCHER_URL=https://rancher.example.com
RANCHER_TOKEN=token-xxxxx:yyyyyyyyy
RANCHER_VERIFY_SSL=true
RANCHER_CA_BUNDLE=
RANCHER_READ_ONLY=false

# Multi-instance mode
# JSON object keyed by instance name. When provided, this is the preferred source.
# Example:
# RANCHER_INSTANCES_JSON={"work":{"url":"https://rancher.work.example.com","token":"token-xxxxx:yyyyyyyyy","verify_ssl":true,"ca_bundle":null,"read_only":false},"lab":{"url":"https://rancher.lab.example.com","token":"token-aaaaa:bbbbbbbbb","verify_ssl":false,"ca_bundle":null,"read_only":true}}
RANCHER_INSTANCES_JSON=
RANCHER_DEFAULT_INSTANCE=default

# Catalog and logging
RANCHER_MCP_CATALOG_PATH=catalog/capabilities.yaml
LOG_LEVEL=INFO
