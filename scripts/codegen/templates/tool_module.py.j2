    instance_name: str,
    {% if cluster_id_required -%}
    cluster_id: str,
    {% endif -%}
    {% if namespaced -%}
    namespace: str,
    {% endif -%}
    {{ get.arg_name }}: str,
    confirmation_phrase_used: str,
    client: {{ client_protocol }},
) -> RancherCuratedDeleteResult:
    """Delete one {{ display_name_singular }}; returns a typed delete result."""

    {% if transport == 'k8s-proxy' -%}
    response_payload = await client.delete_json(
        {{ path_helper.detail_function }}(cluster_id{% if namespaced %}, namespace{% endif %}{% if path_helper.resource_kind %}, "{{ path_helper.resource_kind }}"{% endif %}, {{ get.arg_name }}),
    )
    {%- elif transport == 'steve' or transport == 'norman' -%}
    response_payload = await client.delete_json(f"{{ detail_path }}")
    {%- endif %}
    return RancherCuratedDeleteResult(
        instance=instance_name,
        plane="{{ plane }}",
        resource_kind="{{ display_name_singular }}",
        resource_name={{ get.arg_name }},
        {% if namespaced -%}
        namespace=namespace,
        {% endif -%}
        {% if cluster_id_required -%}
        cluster_id=cluster_id,
        {% endif -%}
        deleted=True,
        confirmation_phrase_used=confirmation_phrase_used,
        response_payload=dict(response_payload),
        suggested_next_steps=[{% for step in delete.next_steps %}"{{ step }}"{% if not loop.last %}, {% endif %}{% endfor %}],
    )


@audit_mutation(operation="{{ delete.audit_operation or (id ~ '_delete') }}", plane="{{ plane }}")
@rate_limit_writes
async def rancher_{{ display_name_singular }}_delete(
    {% if namespaced -%}
    namespace: str,
    {% endif -%}
    {{ get.arg_name }}: str,
    confirmation: str,
    {% if cluster_id_required -%}
    cluster_id: str = "local",
    {% endif -%}
    instance: str | None = None,
    settings: AppSettings | None = None,
    client: {{ client_protocol }} | None = None,
) -> RancherCuratedDeleteResult:
    """Delete one {{ display_name_singular }} after the agent echoes the required confirmation phrase."""

    expected_phrase = f"{{ delete.confirmation_phrase }}"
    if confirmation != expected_phrase:
        raise RancherCapabilityError(
            f"Delete confirmation did not match the required phrase: {expected_phrase!r}"
        )
    resolved_settings = settings or get_settings()
