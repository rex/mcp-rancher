{# ===================== GET OPERATION ===================== #}
{% if 'get' in operations -%}
async def _fetch_{{ display_name_singular }}_get(
    instance_name: str,
    {% if cluster_id_required -%}
    cluster_id: str,
    {% endif -%}
    {% if namespaced -%}
    namespace: str,
    {% endif -%}
    {{ get.arg_name }}: str,
    client: {{ client_protocol }},
) -> {{ detail_model_name }}:
    """Fetch and normalize one {{ display_name_singular }}."""

    {% if transport == 'steve' or transport == 'norman' -%}
    payload = await client.get_json(f"{{ detail_path }}")
    {%- elif transport == 'k8s-proxy' -%}
    payload = await client.get_json(
        {{ path_helper.detail_function }}(cluster_id{% if namespaced %}, namespace{% endif %}{% if path_helper.resource_kind %}, "{{ path_helper.resource_kind }}"{% endif %}, {{ get.arg_name }})
    )
    {%- endif %}
    {% if get.summary_copy_fields -%}
    summary = {{ summary_function }}(payload)
    {% endif -%}
    {%- for local in get.locals %}
    {{ local.name }} = {{ local.expression }}
    {%- endfor %}
    detail = {{ detail_model_name }}.model_validate(payload)
    return detail.model_copy(
        update={
            {%- for field in get.summary_copy_fields %}
            "{{ field }}": summary.{{ field }},
            {%- endfor %}
            {%- for extra in get.extras %}
            "{{ extra.field }}": {{ extra.expression }},
            {%- endfor %}
            {%- if get.include_action_keys %}
            "action_keys": sorted(mapping_value(payload, "actions") or {}),
            {%- endif %}
            {%- if get.include_link_keys %}
            "link_keys": sorted(mapping_value(payload, "links") or {}),
            {%- endif %}
            {%- if get.include_payload %}
            "payload": dict(payload),
            {%- endif %}
            "suggested_next_steps": [{% for step in get.next_steps %}"{{ step }}"{% if not loop.last %}, {% endif %}{% endfor %}],
        }
    )


