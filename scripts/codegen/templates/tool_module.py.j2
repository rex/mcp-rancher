{# ===================== LIST OPERATION ===================== #}
{% if 'list' in operations -%}
async def _fetch_{{ display_name_plural }}_list(
    instance_name: str,
    {% if cluster_id_required -%}
    cluster_id: str,
    {% endif -%}
    {% if namespaced -%}
    namespace: str,
    {% endif -%}
    {%- for filter in list.filters %}
    {{ filter.name }}: {{ filter.type }} | None,
    {%- endfor %}
    {%- for qp in list.query_params if qp != 'continue_token' and qp != 'marker' %}
    {{ qp }}: {{ qp_type(qp) }} | None,
    {%- endfor %}
    client: {{ client_protocol }},
    {%- if pagination %}
    page_token: str | None = None,
    {%- endif %}
) -> {{ list_model_name }}:
    """Fetch and normalize {{ fetch_docstring_phrase }}."""

    query_params = {{ query_builder_function }}(
        {%- for qp in list.query_params %}
        {%- if qp == 'continue_token' or qp == 'marker' %}
        {{ qp_kwarg(qp) }}=page_token,
        {%- else %}
        {{ qp_kwarg(qp) }}={{ qp }},
        {%- endif %}
        {%- endfor %}
    )
    {% if transport == 'steve' or transport == 'norman' -%}
    payload = await client.get_json(f"{{ list_path }}", params=query_params or None)
    {%- elif transport == 'k8s-proxy' -%}
    payload = await client.get_json(
        {{ path_helper.list_function }}(cluster_id{% if namespaced %}, namespace{% endif %}{% if path_helper.resource_kind %}, "{{ path_helper.resource_kind }}"{% endif %}),
        params=query_params or None,
    )
    {%- endif %}
    {{ display_name_plural }} = [{{ summary_function }}(item) for item in {{ items_function }}(payload)]
    {%- for filter in list.filters %}
    {%- if filter.predicate == 'is_true' %}
    if {{ filter.name }} is True:
        {{ display_name_plural }} = [{{ display_name_singular }} for {{ display_name_singular }} in {{ display_name_plural }} if {{ display_name_singular }}.{{ filter.summary_field }} is True]
    {%- else %}
    if {{ filter.name }} is not None:
        {{ display_name_plural }} = [{{ display_name_singular }} for {{ display_name_singular }} in {{ display_name_plural }} if {{ display_name_singular }}.{{ filter.summary_field }} {{ 'is' if filter.type == 'bool' else '==' }} {{ filter.name }}]
    {%- endif %}
    {%- endfor %}
    return {{ list_model_name }}(
        instance=instance_name,
        {% if cluster_id_required -%}
        cluster_id=cluster_id,
        {% endif -%}
        {% if namespaced -%}
        namespace=namespace,
        {% endif -%}
        {{ list.count_field }}=len({{ display_name_plural }}),
        {% if pagination -%}
        next_page_token=next_page_token_from_payload(payload),
        {% endif -%}
        applied_query_params=query_params,
        {{ list.collection_field }}={{ display_name_plural }},
        suggested_next_steps=[
            {%- for step in list.next_steps %}
            "{{ step }}",
            {%- endfor %}
        ],
    )


async def rancher_{{ display_name_plural }}_list(
    {% if namespaced -%}
    namespace: str,
    {% endif -%}
    {% if cluster_id_required -%}
    cluster_id: str = "local",
    {% endif -%}
    {%- for filter in list.filters %}
    {{ filter.name }}: {{ filter.type }} | None = None,
    {%- endfor %}
    {%- for qp in list.query_params if qp != 'continue_token' and qp != 'marker' %}
    {{ qp }}: {{ qp_type(qp) }} | None = None,
    {%- endfor %}
    {% if pagination -%}
    page_token: str | None = None,
    {% endif -%}
    instance: str | None = None,
    settings: AppSettings | None = None,
    client: {{ client_protocol }} | None = None,
) -> {{ list_model_name }}:
    """List {{ display_name_plural }}{{ ' in one namespace' if namespaced else '' }} with typed summaries."""

    resolved_settings = settings or get_settings()
    instance_name, instance_config = resolve_instance(resolved_settings, instance)
    if client is not None:
        return await _fetch_{{ display_name_plural }}_list(
            instance_name,
            {% if cluster_id_required -%}
            cluster_id,
            {% endif -%}
            {% if namespaced -%}
            namespace,
            {% endif -%}
            {%- for filter in list.filters %}
            {{ filter.name }},
            {%- endfor %}
            {%- for qp in list.query_params if qp != 'continue_token' and qp != 'marker' %}
            {{ qp }},
            {%- endfor %}
            client,
            {%- if pagination %}
            page_token,
            {%- endif %}
        )
    {% if transport == 'steve' -%}
    async with {{ client_class }}(
        instance_name,
        instance_config,
        cluster_id=cluster_id,
    ) as {{ client_var }}:
    {%- elif transport == 'k8s-proxy' or transport == 'norman' -%}
    async with {{ client_class }}(instance_name, instance_config) as {{ client_var }}:
    {%- endif %}
        return await _fetch_{{ display_name_plural }}_list(
            instance_name,
            {% if cluster_id_required -%}
            cluster_id,
            {% endif -%}
            {% if namespaced -%}
            namespace,
            {% endif -%}
            {%- for filter in list.filters %}
            {{ filter.name }},
            {%- endfor %}
            {%- for qp in list.query_params if qp != 'continue_token' and qp != 'marker' %}
            {{ qp }},
            {%- endfor %}
            {{ client_var }},
            {%- if pagination %}
            page_token,
            {%- endif %}
        )


{% endif -%}
{# ===================== GET OPERATION ===================== #}
{% if 'get' in operations -%}
async def _fetch_{{ display_name_singular }}_get(
    instance_name: str,
    {% if cluster_id_required -%}
    cluster_id: str,
    {% endif -%}
    {% if namespaced -%}
    namespace: str,
    {% endif -%}
    {{ get.arg_name }}: str,
    client: {{ client_protocol }},
) -> {{ detail_model_name }}:
    """Fetch and normalize one {{ display_name_singular }}."""

    {% if transport == 'steve' or transport == 'norman' -%}
    payload = await client.get_json(f"{{ detail_path }}")
    {%- elif transport == 'k8s-proxy' -%}
    payload = await client.get_json(
        {{ path_helper.detail_function }}(cluster_id{% if namespaced %}, namespace{% endif %}{% if path_helper.resource_kind %}, "{{ path_helper.resource_kind }}"{% endif %}, {{ get.arg_name }})
    )
    {%- endif %}
    {% if get.summary_copy_fields -%}
    summary = {{ summary_function }}(payload)
    {% endif -%}
    {%- for local in get.locals %}
    {{ local.name }} = {{ local.expression }}
    {%- endfor %}
    detail = {{ detail_model_name }}.model_validate(payload)
    return detail.model_copy(
        update={
            {%- for field in get.summary_copy_fields %}
            "{{ field }}": summary.{{ field }},
            {%- endfor %}
            {%- for extra in get.extras %}
            "{{ extra.field }}": {{ extra.expression }},
            {%- endfor %}
            {%- if get.include_action_keys %}
            "action_keys": sorted(mapping_value(payload, "actions") or {}),
            {%- endif %}
            {%- if get.include_link_keys %}
            "link_keys": sorted(mapping_value(payload, "links") or {}),
            {%- endif %}
            {%- if get.include_payload %}
            "payload": dict(payload),
            {%- endif %}
            "suggested_next_steps": [{% for step in get.next_steps %}"{{ step }}"{% if not loop.last %}, {% endif %}{% endfor %}],
        }
    )


async def rancher_{{ display_name_singular }}_get(
    {% if namespaced -%}
    namespace: str,
    {% endif -%}
    {{ get.arg_name }}: str,
    {% if cluster_id_required -%}
    cluster_id: str = "local",
    {% endif -%}
    instance: str | None = None,
    settings: AppSettings | None = None,
    client: {{ client_protocol }} | None = None,
) -> {{ detail_model_name }}:
    """Fetch one {{ display_name_singular }}{{ ' by namespace and name' if namespaced else ' by name' }}."""

    resolved_settings = settings or get_settings()
    instance_name, instance_config = resolve_instance(resolved_settings, instance)
    if client is not None:
        return await _fetch_{{ display_name_singular }}_get(instance_name, {% if cluster_id_required %}cluster_id, {% endif %}{% if namespaced %}namespace, {% endif %}{{ get.arg_name }}, client)
    {% if transport == 'steve' -%}
    async with {{ client_class }}(
        instance_name,
        instance_config,
        cluster_id=cluster_id,
    ) as {{ client_var }}:
    {%- elif transport == 'k8s-proxy' or transport == 'norman' -%}
    async with {{ client_class }}(instance_name, instance_config) as {{ client_var }}:
    {%- endif %}
        return await _fetch_{{ display_name_singular }}_get(
            instance_name,
            {% if cluster_id_required -%}
            cluster_id,
            {% endif -%}
            {% if namespaced -%}
            namespace,
            {% endif -%}
            {{ get.arg_name }},
            {{ client_var }},
        )


{% endif -%}
